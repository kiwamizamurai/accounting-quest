{
  "name": "accounting-game",
  "version": "1.0.0",
  "description": "RPG-style accounting learning game - Learn accounting through a pixel art adventure",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "keywords": [
    "accounting",
    "education",
    "game",
    "phaser",
    "rpg",
    "pixel-art"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.1",
    "@vitest/ui": "^4.0.18",
    "gh-pages": "^6.3.0",
    "jsdom": "^28.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
